# ─────────────────────────────────────────────
# DevFlow — Variables de entorno
# Copiar este archivo a .env y completar los valores
# ─────────────────────────────────────────────

# Base de datos PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://devflow:devflow@localhost:5432/devflow

# JWT
# Cambiar SECRET_KEY por un valor seguro en producción (openssl rand -hex 32)
SECRET_KEY=devflow-secret-change-in-prod
TOKEN_EXPIRE_MINUTES=480

# CORS — orígenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Claude API (usado por el agente IA en el frontend, no en este backend)
# Se mantiene aquí como referencia para cuando el agente migre al backend
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# Integración GitHub
# OAuth App:  https://github.com/settings/developers
#   - Authorization callback URL = GITHUB_OAUTH_REDIRECT_URI
# GITHUB_TOKEN: PAT (fine-grained) o token de GitHub App con permiso
#   issues:write sobre el repo GITHUB_REPO. Lo usa el backend para crear
#   los issues (acción solo-admin), independiente del OAuth de login.
# ─────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8000/auth/github/callback
FRONTEND_URL=http://localhost:3000
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
