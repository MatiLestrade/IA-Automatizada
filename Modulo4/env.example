# ─────────────────────────────────────────────
# DevFlow — Variables de entorno
# Copiar este archivo a .env y completar los valores
# ─────────────────────────────────────────────

# Base de datos PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://devflow:devflow@localhost:5432/devflow

# JWT
# Cambiar SECRET_KEY por un valor seguro en producción (openssl rand -hex 32)
SECRET_KEY=devflow-secret-change-in-prod
TOKEN_EXPIRE_MINUTES=480

# CORS — orígenes permitidos separados por coma
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Claude API — usada por el backend para el análisis IA de los tickets
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────
# Integración GitHub (issues + lectura de código por la IA)
# GITHUB_TOKEN: PAT fine-grained con permisos sobre el/los repo(s):
#   - Issues: Read and write   → crear/cerrar/reabrir issues desde los tickets.
#   - Contents: Read           → que la IA lectora navegue y lea el código del repo.
# GITHUB_REPO: repo destino por defecto (formato owner/repo). Cada cliente
#   puede sobreescribirlo con su propio repo desde la página Clientes.
# ─────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
